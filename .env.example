# Reddit retrieval needs NO credentials -- brainrotbot reads public RSS feeds.
# Copy to .env (gitignored); loaded automatically by config.load_settings().
# This file is a COMMITTED TEMPLATE -- put placeholders here, real secrets only in .env.

# Step 6 (thumbnail) -- free Pixabay API key from https://pixabay.com/api/docs/
PIXABAY_API_KEY="your-pixabay-key-here"

# Step 7 (TikTok upload) needs NO username/password here: auth is a one-time interactive
# browser login -- run `run.bat --tiktok-login`, sign in once in the window that opens, and
# the session persists in config/tiktok_profile/ (gitignored). Nothing to store in this file.
